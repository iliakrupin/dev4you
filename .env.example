# Скопируйте этот файл в .env.local и заполните значения.
# .env.local в .gitignore — он НЕ попадёт в репозиторий.

# ---- База данных (Vercel Postgres / Neon) ----
# Получить: vercel link → vercel env pull .env.local
# Vercel Postgres даёт переменную DATABASE_URL автоматически.
DATABASE_URL=

# ---- Telegram Bot ----
# Получить: @BotFather → /newbot или /token (если ревокнули)
# КРИТИЧНО: никогда не коммитить, не отправлять в чат.
TELEGRAM_BOT_TOKEN=
# Username бота без @ (напр. dev4you_bot)
TELEGRAM_BOT_USERNAME=

# ---- GitHub (для агента — push кода, открытие PR) ----
# fine-grained PAT на репо iliakrupin/dev4you с правами:
#   Contents: write, Pull requests: write, Metadata: read
# https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=
GITHUB_OWNER=iliakrupin
GITHUB_REPO=dev4you
# Базовая ветка
GITHUB_BASE_BRANCH=main

# ---- LLM (внутренний Qwen, OpenAI-compatible) ----
QWEN_BASE_URL=http://212.41.6.240:9999/v1
# Имя модели (получить: curl $QWEN_BASE_URL/models)
QWEN_MODEL=Qwen/Qwen3.5-27B-GPTQ-Int4
# API key — если эндпоинт его требует, иначе оставьте dummy-значение
QWEN_API_KEY=dummy

# ---- App ----
# Публичный URL приложения (заполнится после Vercel deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000
